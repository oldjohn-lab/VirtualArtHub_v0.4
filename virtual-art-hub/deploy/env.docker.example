# Copy to project root as .env.docker for docker compose --env-file

# npm 镜像（Docker 构建 npm ci 用；国内推荐默认；海外可改为 https://registry.npmjs.org）
NPM_CONFIG_REGISTRY=https://registry.npmmirror.com

# 前端 Docker 构建 Node 堆上限（MB）；react-scripts 在容器内易 OOM，默认 8192，仍失败可试 10240 并增大 Docker Desktop 内存
# CRA_NODE_MEMORY_MB=8192

MYSQL_ROOT_PASSWORD=vah_root_dev
DB_NAME=virtual_art_hub_cursor
DB_USER=vah_app
DB_PASSWORD=vah_app_pass
JWT_SECRET=replace-with-long-random-string

MYSQL_PUBLISH_PORT=3306
VAH_GATEWAY_PUBLISH_PORT=5002
VAH_WEB_PUBLISH_PORT=8080
