# Copy to project root as .env.prod for docker compose --env-file .env.prod -f docker-compose.prod.yml up -d

# Image repository prefix and tag used by docker-compose.prod.yml
# Example for GitHub Container Registry:
# IMAGE_REPO=ghcr.io/oldjohn-lab/virtualarthub_v0.4
IMAGE_REPO=ghcr.io/oldjohn-lab/virtualarthub_v0.4
IMAGE_TAG=latest

MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
DB_NAME=virtual_art_hub_cursor
DB_USER=vah_app
DB_PASSWORD=replace-with-strong-db-password
JWT_SECRET=replace-with-long-random-string

MYSQL_PUBLISH_PORT=3306
VAH_GATEWAY_PUBLISH_PORT=5002
VAH_WEB_PUBLISH_PORT=8080
