PORT=5002
# 全站 HTTPS：设为 1 后需在 certs/ 放置 PEM（默认 localhost-key.pem、localhost.pem）
# USE_HTTPS=1
# SSL_KEY_PATH=./certs/localhost-key.pem
# SSL_CERT_PATH=./certs/localhost.pem
# 自签示例（在 backend-koa/certs 下执行，需已安装 openssl）：
# openssl req -x509 -newkey rsa:2048 -keyout localhost-key.pem -out localhost.pem -days 825 -nodes -subj "/CN=localhost"
JWT_SECRET=change_me
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=virtual_art_hub_cursor
DB_USER=change_me
DB_PASSWORD=change_me
